{
  "expo": {
    "name": "Fairway",
    "slug": "fairway",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fairway",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fairway.app"
    },
    "android": {
      "package": "com.fairway.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
