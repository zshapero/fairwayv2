{
  "expo": {
    "name": "Fairway",
    "slug": "fairway",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fairway",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#1F4D3F",
    "splash": {
      "backgroundColor": "#FAF6EE",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fairway.app",
      "splash": {
        "backgroundColor": "#FAF6EE",
        "resizeMode": "contain"
      }
    },
    "android": {
      "package": "com.fairway.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#1F4D3F"
      },
      "splash": {
        "backgroundColor": "#FAF6EE",
        "resizeMode": "contain"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "backgroundColor": "#FAF6EE"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
