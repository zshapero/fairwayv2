# Copy this file to .env and fill in real values for local development.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the client bundle.

EXPO_PUBLIC_APP_NAME=Fairway

# GolfCourseAPI key — get one at https://golfcourseapi.com (free tier is 300 req/day).
# Read at runtime via process.env.EXPO_PUBLIC_GOLF_COURSE_API_KEY.
EXPO_PUBLIC_GOLF_COURSE_API_KEY=
